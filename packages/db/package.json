{
  "name": "@meridian/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "migrate": "drizzle-kit migrate",
    "generate": "drizzle-kit generate",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@meridian/shared": "workspace:*",
    "neo4j-driver": "^5.27.0",
    "drizzle-orm": "^0.39.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.8.0"
  }
}
